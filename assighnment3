4)Create a procedure which will accept Deptno and display  no of employee under different grade
Ans:
CREATE OR REPLACE PROCEDURE emp_details(
 p_deptno IN NUMBER
) IS
BEGIN
    FOR r IN (
             SELECT s.grade, count(*) cnt
              from emp e, salgrade s
              where e.deptno = p_deptno
              GROUP BY s.grade
              ORDER BY s.grade
              ) LOOP 
           DBMS_OUTPUT.PUT_LINE(r.grade || r.cnt);
     END LOOP;
END;
/
5)write a function total salary dept that returns the total salary dept that returns the total salary dept the return total salary of all employee in a given department .
Ans:
CREATE OR REPLACE FUNCTION total_salary_dept(
               dno IN NUMBER
)
RETURN NUMBER
IS
      total_sal NUMBER;
BEGIN
        SELECT sum(sal)
         INTO total_sal
         FROM emp
        where deptno = dno;
        return total_sal;
END;
/



