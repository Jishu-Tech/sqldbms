7)write a function cal_bonous that return bonous for an employee as20 % of salary
Ans:
CREATE OR REPLACE FUNCTION cal_bonus(
p_no IN NUMBER
)
RETURN NUMBER
IS
  new_sal emp.sal%type;
BEGIN
  SELECT sal
  into new_sal
  from emp
  where empno = p_no;
  return new_sal * 0.20;
END;
/
8)Write a procedure show_emp that accept an employee ID and prints name, salary & DeptName
Ans:
CREATE OR REPLACE PROCEDURE show_emp(
 e_id IN NUMBER
) IS
  v_name emp.ename%type;
  v_sal emp.sal%type;
  v_dept emp.dname%type;
BEGIN
  SELECT e.ename, e.sal, d.dname
  INTO v_name, v_sal, v_dept
  from emp e, dept d
  where e.deptno = d.deptno
  AND e.empno = e_id
  DBMS_OUTPUT.PUT_LINE(v_name || v_sal || v_dept);
END;
/
9)Create a procedure update salary that increases of the salary of given employee by a given percentage parameters: employee ID, percentage 
Ans:
CREATE OR REPLACE PROCEDURE update_salary(
p_emp_id IN NUMBER,
p_percentage IN NUMBER
)
IS
BEGIN
UPDATE emp
SET salary = salary + (salary * p_percentage / 100)
WHERE empno = p_emp_id;
END;
/
10)Write a function calculate_age(p_emp_id NUMBER) that  retrieves the employee’s DOB ,calculate age in years &  return age 
Ans:
CREATE OR RELACE FUNCTION calculate_age(
 p_emp_id IN NUMBER
)is
 v_dob DATE;
 v_age NUMBER;
BEGIN 
  SELECT dob
  INTO v_dob
  from emp
  where empno=p_emp_id;
  v_age:=FLOOR(MONTHS_BETWEEN(SYSDATE,v_dob)/12);
  return v_age;
END;
/
