2)Aspect an employs salary and determine the grade if salary is more then 50,000 then grade A if the number is more then 30,000 then grade B  if the salary is less then 30,000 then grade C
Ans:
  SET SERVEROUTPUT ON;
SET VERIFY OFF;
DECLARE
   vi NUMBER;
BEGIN
   vi := &Enter_Value;
   IF vi >= 50000 THEN
      dbms_output.put_line('Grade A');
   ELSIF vi >= 30000 THEN
      dbms_output.put_line('Grade B');
   ELSE
      dbms_output.put_line('Grade C');
   END IF;
END;
/


