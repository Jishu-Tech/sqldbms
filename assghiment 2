4)write a sql programme to generate Fibonacci series?
Ans:
SET SERVEROUTPUT ON;
SET VERIFY OFF;
DECLARE
    a INT := 0;
    b INT := 1;
    c INT;
    n INT;
BEGIN
    n := &n;
    FOR i IN 1..n LOOP
        DBMS_OUTPUT.PUT_LINE(a);
        c := a + b;
        a := b;
        b := c;
    END LOOP;
END;
/
