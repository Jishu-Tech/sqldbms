6)Write a pl/sql programme to display an given number in reverse order?
Ans:
 DECLARE
    n int;
    rev int:=0;
BEGIN
    n:= &n;
    WHILE  n>0 LOOP
        rev := rev *10+MOD(n,10);
        n:=n/10;
    END LOOP;
    dbms_output.put_line('Reversed Number =' || rev);
   END;
   /
7)write a pl/sql programme to take a  department ID and department name using case
Ans:
    SET SERVEROUTPUT ON;
SET VERIFY OFF;
DECLARE
   a INT;
BEGIN
   a := &a;
   CASE a
      WHEN 10 THEN DBMS_OUTPUT.PUT_LINE('Finance’);
      WHEN 20 THEN DBMS_OUTPUT.PUT_LINE('HR’);
      WHEN 30 THEN DBMS_OUTPUT.PUT_LINE('IT’);
      WHEN 40 THEN DBMS_OUTPUT.PUT_LINE('Sales’);
      ELSE DBMS_OUTPUT.PUT_LINE('Invalid Department’);
   END CASE;
END;
/
8)write a pl/sql block using for loop to print the sum of first 100 odd numbers 
Ans:
SET SERVEROUTPUT ON;
DECLARE
   v_sum NUMBER := 0;
BEGIN
   FOR i IN 1..100 LOOP
      v_sum := v_sum + (2*i - 1);
   END LOOP;
   DBMS_OUTPUT.PUT_LINE('Sum of first 100 odd numbers = ' || v_sum);
END;
/

